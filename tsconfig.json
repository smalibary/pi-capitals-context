{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"types": ["node"],
		"lib": ["ES2022"]
	},
	"include": ["extensions/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
}
