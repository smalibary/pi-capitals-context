{
  "name": "pi-capitals-context",
  "version": "2.0.0",
  "description": "Auto-inject ALL_CAPS context files into pi's system prompt — per-file toggles, folder collapse, global ~/.pi/CAPS, search, sort, preview, file watcher",
  "main": "extensions/index.ts",
  "keywords": ["pi-package"],
  "author": "Salem Malibary <salem.thecreativeconsult@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smalibary/pi-capitals-context.git"
  },
  "homepage": "https://github.com/smalibary/pi-capitals-context#readme",
  "bugs": {
    "url": "https://github.com/smalibary/pi-capitals-context/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": ["./extensions"],
    "image": "./screenshot.png"
  }
}
